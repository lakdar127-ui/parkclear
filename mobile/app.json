{
  "expo": {
    "name": "ParkClear",
    "slug": "parkclear",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.parkclear.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ParkClear utilise la caméra pour photographier les véhicules abandonnés.",
        "NSPhotoLibraryUsageDescription": "ParkClear peut accéder à vos photos pour documenter les signalements."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "fr.parkclear.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      ["expo-camera", { "cameraPermission": "ParkClear utilise la caméra pour photographier les véhicules abandonnés." }],
      ["expo-notifications", { "color": "#16a34a" }]
    ],
    "scheme": "parkclear",
    "experiments": { "typedRoutes": true }
  }
}
